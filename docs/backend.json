
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user, linked to an Organization for RBAC.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "organizationId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "finance", "engineer"] },
        "isEmailVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "organizationId", "role"]
    },
    "Organization": {
      "title": "Organization",
      "type": "object",
      "description": "B2B Org container for teams and billing.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "revenueStage": { "type": "string" },
        "apiBudgetUsd": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "AISubscription": {
      "title": "AISubscription",
      "type": "object",
      "description": "Stores provider metadata and connection status.",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "providerName": { "type": "string" },
        "customName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "error", "pending"] },
        "monthlyFixedCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "organizationId", "providerName"]
    },
    "IngestKey": {
      "title": "IngestKey",
      "type": "object",
      "description": "Hashed ingest key for SDK authentication.",
      "properties": {
        "id": { "type": "string" },
        "hash": { "type": "string" },
        "prefix": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "revoked"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUsedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "hash", "status"]
    },
    "UsageRecord": {
      "title": "UsageRecord",
      "type": "object",
      "description": "Request-level token usage record.",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "model": { "type": "string" },
        "provider": { "type": "string" },
        "inputTokens": { "type": "number" },
        "outputTokens": { "type": "number" },
        "cost": { "type": "number" },
        "eventId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/organizations/{orgId}": {
      "schema": "#/backend/entities/Organization",
      "description": "Root org document."
    },
    "/organizations/{orgId}/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Users within the org."
    },
    "/users/{userId}/aiSubscriptions/{subId}": {
      "schema": "#/backend/entities/AISubscription",
      "description": "API connections for the user."
    },
    "/users/{userId}/aiSubscriptions/{subId}/ingestKeys/{keyId}": {
      "schema": "#/backend/entities/IngestKey",
      "description": "Scoped, hashed keys for this subscription."
    },
    "/users/{userId}/aiSubscriptions/{subId}/apiUsageRecords/{recordId}": {
      "schema": "#/backend/entities/UsageRecord",
      "description": "Ingested forensic data."
    }
  }
}
