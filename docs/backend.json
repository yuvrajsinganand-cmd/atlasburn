
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user, linked to an Organization for RBAC.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "organizationId": { "type": "string", "description": "Link to the Org entity." },
        "role": { "type": "string", "enum": ["owner", "admin", "finance", "engineer"] },
        "isEmailVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "organizationId", "role"]
    },
    "Organization": {
      "title": "Organization",
      "type": "object",
      "description": "B2B Org container for teams and billing.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "revenueStage": { "type": "string" },
        "apiBudgetUsd": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "AISubscription": {
      "title": "AISubscription",
      "type": "object",
      "description": "Stores provider credentials (encrypted) and connection status.",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "providerName": { "type": "string" },
        "customName": { "type": "string" },
        "apiKeyMetadata": { "type": "string", "description": "Encrypted metadata or masked key." },
        "status": { "type": "string", "enum": ["active", "error", "pending"] },
        "monthlyFixedCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "organizationId", "providerName"]
    },
    "DailyRollup": {
      "title": "DailyRollup",
      "type": "object",
      "description": "Pre-aggregated time-series data for the dashboard.",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "costUsd": { "type": "number" },
        "tokensIn": { "type": "number" },
        "tokensOut": { "type": "number" },
        "requestCount": { "type": "number" },
        "topFeature": { "type": "string" }
      },
      "required": ["id", "organizationId", "date", "costUsd"]
    },
    "Anomaly": {
      "title": "Anomaly",
      "type": "object",
      "description": "Detected spend spikes with automated explanations.",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "severity": { "type": "string" },
        "description": { "type": "string" },
        "primaryDriver": { "type": "string" },
        "isResolved": { "type": "boolean" }
      },
      "required": ["id", "organizationId", "timestamp", "severity", "description"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/organizations/{orgId}",
        "definition": {
          "entityName": "Organization",
          "schema": { "$ref": "#/backend/entities/Organization" },
          "description": "Root org document."
        }
      },
      {
        "path": "/organizations/{orgId}/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Users within the org."
        }
      },
      {
        "path": "/organizations/{orgId}/subscriptions/{subId}",
        "definition": {
          "entityName": "AISubscription",
          "schema": { "$ref": "#/backend/entities/AISubscription" },
          "description": "API connections for the org."
        }
      },
      {
        "path": "/organizations/{orgId}/dailyRollups/{rollupId}",
        "definition": {
          "entityName": "DailyRollup",
          "schema": { "$ref": "#/backend/entities/DailyRollup" },
          "description": "Pre-computed metrics."
        }
      },
      {
        "path": "/organizations/{orgId}/anomalies/{anomalyId}",
        "definition": {
          "entityName": "Anomaly",
          "schema": { "$ref": "#/backend/entities/Anomaly" },
          "description": "Spend spikes."
        }
      }
    ]
  }
}
