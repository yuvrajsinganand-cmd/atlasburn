
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user, linked to an Organization and a User Tier for margin analysis.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "organizationId": { "type": "string" },
        "userTier": { "type": "string", "enum": ["free", "pro", "enterprise"], "description": "Used to calculate revenue-vs-burn per user." },
        "role": { "type": "string", "enum": ["owner", "admin", "finance", "engineer"] },
        "status": { "type": "string", "enum": ["active", "pending", "disabled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "organizationId", "role", "userTier"]
    },
    "Organization": {
      "title": "Organization",
      "type": "object",
      "description": "The Economic Container. Stores capital, revenue targets, budget guardrails, and allowed domains.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "capitalReserves": { "type": "number", "description": "Total cash available for API burn." },
        "monthlyRevenue": { "type": "number", "description": "Current monthly recurring revenue (MRR)." },
        "fixedMonthlyBurn": { "type": "number", "description": "Manual override for institutional baseline burn." },
        "targetMargin": { "type": "number", "description": "Desired gross margin percentage (e.g. 0.7 for 70%)." },
        "allowedDomains": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "domain": { "type": "string" },
              "verified": { "type": "boolean" },
              "verificationToken": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "AISubscription": {
      "title": "AISubscription",
      "type": "object",
      "description": "A tracked AI service or an internal ingestion project.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "providerName": { "type": "string" },
        "monthlyFixedCost": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "IngestKey": {
      "title": "IngestKey",
      "type": "object",
      "description": "A secure HMAC-SHA-256 hashed credential for SDK telemetry.",
      "properties": {
        "hash": { "type": "string", "description": "The HMAC hash of the raw API key." },
        "prefix": { "type": "string", "description": "Non-sensitive prefix for UI display (e.g. abn_abcd...)." },
        "status": { "type": "string", "enum": ["active", "revoked"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUsedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GuardrailConfig": {
      "title": "GuardrailConfig",
      "type": "object",
      "description": "Configuration for the Auto Kill safety system.",
      "properties": {
        "enabled": { "type": "boolean" },
        "dailyBudgetUsd": { "type": "number" },
        "hourlyBudgetUsd": { "type": "number" },
        "perFeatureBudgetUsd": { "type": "number" },
        "maxRetryCascadeRisk": { "type": "number" },
        "maxLoopRiskScore": { "type": "number" },
        "mode": { "type": "string", "enum": ["alert", "soft_stop", "hard_stop"] },
        "status": { "type": "string", "enum": ["active", "throttled", "suspended"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GuardrailBreach": {
      "title": "GuardrailBreach",
      "type": "object",
      "description": "Record of a safety threshold violation.",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "triggerType": { "type": "string" },
        "observedValue": { "type": "number" },
        "thresholdValue": { "type": "number" },
        "actionTaken": { "type": "string" },
        "featureId": { "type": "string" }
      }
    },
    "Feature": {
      "title": "Feature",
      "type": "object",
      "description": "A product capability that consumes AI resources.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "expectedTokensPerCall": { "type": "number" }
      },
      "required": ["id", "name"]
    },
    "UsageRecord": {
      "title": "UsageRecord",
      "type": "object",
      "description": "Atomic economic event: token consumption attributed to a feature and user.",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "model": { "type": "string" },
        "provider": { "type": "string" },
        "featureId": { "type": "string" },
        "userTier": { "type": "string" },
        "inputTokens": { "type": "number" },
        "outputTokens": { "type": "number" },
        "cost": { "type": "number" },
        "eventId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/organizations/{orgId}": {
      "schema": "#/backend/entities/Organization",
      "description": "Economic root."
    },
    "/users/{userId}/aiSubscriptions/{subId}": {
      "schema": "#/backend/entities/AISubscription",
      "description": "A user's AI tool inventory."
    },
    "/users/{userId}/aiSubscriptions/{subId}/ingestKeys/{keyId}": {
      "schema": "#/backend/entities/IngestKey",
      "description": "Hashed SDK credentials."
    },
    "/organizations/{orgId}/guardrail/config": {
      "schema": "#/backend/entities/GuardrailConfig",
      "description": "Auto Kill safety parameters."
    },
    "/organizations/{orgId}/breaches/{breachId}": {
      "schema": "#/backend/entities/GuardrailBreach",
      "description": "Safety violation ledger."
    },
    "/organizations/{orgId}/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Attribution identities."
    },
    "/organizations/{orgId}/usageRecords/{recordId}": {
      "schema": "#/backend/entities/UsageRecord",
      "description": "Forensic ledger."
    }
  }
}
