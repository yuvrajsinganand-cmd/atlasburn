{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user, linked to an Organization and a User Tier for margin analysis.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "organizationId": { "type": "string" },
        "userTier": { "type": "string", "enum": ["free", "pro", "enterprise"], "description": "Used to calculate revenue-vs-burn per user." },
        "role": { "type": "string", "enum": ["owner", "admin", "finance", "engineer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "organizationId", "role", "userTier"]
    },
    "Organization": {
      "title": "Organization",
      "type": "object",
      "description": "The Economic Container. Stores capital, revenue targets, budget guardrails, and allowed domains.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "capitalReserves": { "type": "number", "description": "Total cash available for API burn." },
        "monthlyRevenue": { "type": "number", "description": "Current monthly recurring revenue (MRR)." },
        "fixedMonthlyBurn": { "type": "number", "description": "Manual override for institutional baseline burn." },
        "targetMargin": { "type": "number", "description": "Desired gross margin percentage (e.g. 0.7 for 70%)." },
        "allowedDomains": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "domain": { "type": "string" },
              "verified": { "type": "boolean" },
              "verificationToken": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "Feature": {
      "title": "Feature",
      "type": "object",
      "description": "A product capability that consumes AI resources.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "expectedTokensPerCall": { "type": "number" }
      },
      "required": ["id", "name"]
    },
    "UsageRecord": {
      "title": "UsageRecord",
      "type": "object",
      "description": "Atomic economic event: token consumption attributed to a feature and user.",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "model": { "type": "string" },
        "provider": { "type": "string" },
        "featureId": { "type": "string" },
        "userTier": { "type": "string" },
        "inputTokens": { "type": "number" },
        "outputTokens": { "type": "number" },
        "cost": { "type": "number" },
        "eventId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/organizations/{orgId}": {
      "schema": "#/backend/entities/Organization",
      "description": "Economic root."
    },
    "/organizations/{orgId}/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Attribution identities."
    },
    "/organizations/{orgId}/features/{featureId}": {
      "schema": "#/backend/entities/Feature",
      "description": "Product catalog."
    },
    "/organizations/{orgId}/usageRecords/{recordId}": {
      "schema": "#/backend/entities/UsageRecord",
      "description": "Forensic ledger."
    }
  }
}
