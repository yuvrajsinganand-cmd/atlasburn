
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Organization level rules. 
     */
    match /organizations/{orgId} {
      allow read, write: if isOwner(orgId.replace('org_', '')) || exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid));
      match /{allChildren=**} {
        allow read, write: if isOwner(orgId.replace('org_', '')) || exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid));
      }
    }

    /**
     * @description Root User level rules.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /aiSubscriptions/{subId} {
        allow read, write: if isOwner(userId);

        // Usage records can only be read by the owner. 
        // Ingestion API writes them via the service-side initializeApp flow.
        match /apiUsageRecords/{recordId} {
          allow read: if isOwner(userId);
          allow write: if false; // Only written via secure ingestion flow
        }

        match /ingestKeys/{keyId} {
          allow read: if isOwner(userId);
          allow write: if isOwner(userId);
        }

        match /deduplicatedEvents/{eventId} {
          allow read: if isOwner(userId);
          allow write: if false; // Ingestion-internal
        }
      }

      match /{allChildren=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /aiProductOfferings/{offeringId} {
      allow get, list: if true;
    }
  }
}
