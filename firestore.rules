rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AISleek Security Rules - Production Hardened
     *
     * CORE PHILOSOPHY:
     * Implements a strict owner-access model. Users have full control over documents
     * within paths that match their UID or their personal organization (org_UID).
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrgOwner(orgId) {
      return isSignedIn() && (orgId == 'org_' + request.auth.uid);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Organization level rules. 
     * Users have full access to their personal 'org_{uid}' container.
     */
    match /organizations/{orgId} {
      allow get, create, update: if isOrgOwner(orgId) || exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid));
      allow list: if isSignedIn();

      /**
       * @description Nested user profiles within the organization.
       */
      match /users/{userId} {
        allow get, list, create, update: if isOwner(userId) || isOrgOwner(orgId);
        allow delete: if false;
      }
    }

    /**
     * @description Root UserProfile documents.
     */
    match /users/{userId} {
      allow get, list, create, update: if isOwner(userId);
      allow delete: if false;

      /**
       * @description User-specific AI subscriptions.
       */
      match /aiSubscriptions/{subscriptionId} {
        allow read, write: if isOwner(userId);

        /**
         * @description Usage records for specific subscriptions.
         */
        match /apiUsageRecords/{recordId} {
          allow read, write: if isOwner(userId);
        }
      }

      /**
       * @description Cost optimization suggestions.
       */
      match /optimizationSuggestions/{suggestionId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Budget settings and current spending trackers.
       */
      match /userBudgets/{budgetId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description System-generated notifications and alerts.
       */
      match /alerts/{alertId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Public catalog of AI models.
     */
    match /aiProductOfferings/{offeringId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Admin role registration.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}