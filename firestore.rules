
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Organization level rules. 
     * Uses robust string concatenation for ownership verification.
     */
    match /organizations/{orgId} {
      
      function isOrgOwner() {
        return isSignedIn() && orgId == 'org_' + request.auth.uid;
      }
      
      function isOrgMember() {
        return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid));
      }

      // Root org document access
      allow read, write: if isOrgOwner() || isOrgMember();
      
      // All telemetry and audit logs
      match /{allChildren=**} {
        allow read, write: if isOrgOwner() || isOrgMember();
      }
    }

    /**
     * @description Root User level rules.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /aiSubscriptions/{subId} {
        allow read, write: if isOwner(userId);

        // Allow public read for backend key verification in this prototype
        match /ingestKeys/{recordId} {
          allow read: if true;
          allow write: if isOwner(userId);
        }
      }

      match /{allChildren=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /aiProductOfferings/{offeringId} {
      allow get, list: if true;
    }
  }
}
