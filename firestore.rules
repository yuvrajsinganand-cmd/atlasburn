rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AISleek Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict user-ownership model. The majority of data is private 
     * and sequestered within user-specific subcollections. Authorization decisions are 
     * primarily made based on the hierarchy of the request path and denormalized identity 
     * fields within the documents.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Organization level rules. Users can access their own organization.
     */
    match /organizations/{orgId} {
      allow get: if isSignedIn() && (orgId == 'org_' + request.auth.uid || exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)));
      allow create: if isSignedIn() && (orgId == 'org_' + request.auth.uid);
      allow update: if isSignedIn() && (orgId == 'org_' + request.auth.uid);
      allow list: if isSignedIn();
    }

    /**
     * @description User profiles within organizations.
     */
    match /organizations/{orgId}/users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Rules for root UserProfile documents.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && (request.resource.data.id == userId || !('id' in request.resource.data));
      allow update: if isExistingOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Public catalog of AI models.
     */
    match /aiProductOfferings/{offeringId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description User-specific AI subscriptions.
     */
    match /users/{userId}/aiSubscriptions/{subscriptionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Usage records for specific subscriptions.
     */
    match /users/{userId}/aiSubscriptions/{subscriptionId}/apiUsageRecords/{recordId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Cost optimization suggestions.
     */
    match /users/{userId}/optimizationSuggestions/{suggestionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Budget settings and current spending trackers.
     */
    match /users/{userId}/userBudgets/{budgetId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description System-generated notifications and alerts.
     */
    match /users/{userId}/alerts/{alertId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Admin role registration.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}