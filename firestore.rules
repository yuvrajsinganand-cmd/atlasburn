rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AISleek Security Rules - Hardened for Founder Mode
     *
     * CORE PHILOSOPHY:
     * Users have full read/write access to any document within their personal 
     * user subtree or their personalized organization subtree.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrgOwner(orgId) {
      return isSignedIn() && (orgId == 'org_' + request.auth.uid);
    }

    // --- Collection Rules ---

    /**
     * @description Organization level rules. 
     * Owners have full access to their personal 'org_{uid}' container and all nested data.
     */
    match /organizations/{orgId} {
      // Allow access if user is the direct org owner (via UID prefix) 
      // or if they exist as a user within that organization.
      allow read, write: if isOrgOwner(orgId) || exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid));

      /**
       * @description Recursive match for all nested organizational data.
       */
      match /{allChildren=**} {
        allow read, write: if isOrgOwner(orgId) || exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid));
      }
    }

    /**
     * @description Root User level rules.
     * Owners have full access to their own user profile and all nested sub-collections.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      /**
       * @description Recursive match for all nested user-specific data 
       * (aiSubscriptions, apiUsageRecords, userBudgets, alerts, etc).
       */
      match /{allChildren=**} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Public catalog of AI models.
     */
    match /aiProductOfferings/{offeringId} {
      allow get, list: if true;
    }

    /**
     * @description Admin role registration.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      allow write: if false; // Admin roles are system-assigned
    }
  }
}