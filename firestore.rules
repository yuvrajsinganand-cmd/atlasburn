
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Organization level rules. 
     */
    match /organizations/{orgId} {
      
      function isOrgOwner() {
        return isSignedIn() && orgId == 'org_' + request.auth.uid;
      }
      
      function isOrgMember() {
        return isSignedIn() && exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid));
      }

      // Allow reads only for members
      allow read: if isOrgOwner() || isOrgMember();
      
      // Allow root document writes for owners
      allow write: if isOrgOwner();

      // INGESTION PATHS: Allow writes for telemetry and audit logs
      // These are targets for the Ingest API which may not have a request.auth context
      match /usageRecords/{recordId} {
        allow read: if isOrgOwner() || isOrgMember();
        allow write: if true; 
      }

      match /auditLogs/{logId} {
        allow read: if isOrgOwner() || isOrgMember();
        allow write: if true;
      }

      match /breaches/{breachId} {
        allow read: if isOrgOwner() || isOrgMember();
        allow write: if true;
      }

      match /guardrail/config {
        allow read: if isOrgOwner() || isOrgMember();
        allow write: if isOrgOwner();
      }

      match /{allChildren=**} {
        allow read: if isOrgOwner() || isOrgMember();
        allow write: if isOrgOwner();
      }
    }

    /**
     * @description User level rules for subscriptions and keys.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /aiSubscriptions/{subId} {
        allow read, write: if isOwner(userId);
        
        match /ingestKeys/{keyId} {
          // Allow writes for the Ingest API to update 'lastUsedAt'
          allow read: if isOwner(userId);
          allow write: if isOwner(userId) || request.auth == null;
        }
      }

      match /{allChildren=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /aiProductOfferings/{offeringId} {
      allow get, list: if true;
    }
  }
}
